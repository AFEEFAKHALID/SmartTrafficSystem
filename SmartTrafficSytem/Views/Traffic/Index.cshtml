@{
    ViewData["Title"] = "Traffic Monitoring";
}

<div class="container-fluid">

    
    <h2 class="mb-4">
        🚗 Live Traffic Monitoring Center
    </h2>

    <!-- Summary Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <h5>Total Active Roads</h5>
                    <h3>15</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body">
                    <h5>Low Traffic Roads</h5>
                    <h3>4</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body">
                    <h5>High Traffic Roads</h5>
                    <h3>6</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body">
                    <h5>Emergency Routes</h5>
                    <h3>2</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Live Traffic Table -->

