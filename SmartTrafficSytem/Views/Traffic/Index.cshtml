                    <tr>

                        <th>Road Name</th>
                        <th>Vehicles</th>
                        <th>Traffic Condition</th>
                        <th>Ambulance</th>
                        <th>Signal Status</th>
                        <th>Priority</th>

                    </tr>

                </thead>

                <tbody>

