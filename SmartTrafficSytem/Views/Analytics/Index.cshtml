@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="container-fluid">

    <h2 class="mb-4">
        📊 Smart Traffic Analytics Dashboard
    </h2>

    <!-- Main Dashboard Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5>Total Roads</h5>
                    <h3>@ViewBag.TotalRoads</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h5>Total Vehicles</h5>
                    <h3>@ViewBag.TotalVehicles</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5>Emergencies</h5>
                    <h3>@ViewBag.TotalEmergencies</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h5>Signals</h5>
                    <h3>@ViewBag.TotalSignals</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Analytics Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6>Most Congested Road</h6>
                    <h4>@ViewBag.TopRoad</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6>Fastest Road</h6>
                    <h4>@ViewBag.FastestRoad</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h6>Average Speed</h6>
                    <h4>@ViewBag.AverageSpeed km/h</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6>Most Common Traffic</h6>
                    <h4>@ViewBag.MostCommonTraffic</h4>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Vehicle Count Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Vehicle Count by Road
        </div>

        <div class="card-body">
            <canvas id="vehicleChart"></canvas>
        </div>

    </div>

    <br />

    <!-- Traffic Distribution Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Traffic Level Distribution
        </div>

        <div class="card-body">
            <canvas id="trafficPieChart"></canvas>
        </div>

    </div>

    <br />

    <!-- Emergency Distribution -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Emergency Vehicle Distribution
        </div>

        <div class="card-body">
            <canvas id="emergencyChart"></canvas>
        </div>

    </div>

    <br />

    <!-- Top Roads Table -->

    <div class="card">

        <div class="card-header bg-danger text-white">
            Top 5 Congested Roads
        </div>

        <div class="card-body">

            <table class="table table-striped table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Road Name</th>
                        <th>Vehicle Count</th>
                        <th>Traffic Level</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in ViewBag.TopRoads)
                    {
                        <tr>
                            <td>@item.RoadName</td>
                            <td>@item.VehicleCount</td>
                            <td>@item.TrafficLevel</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <!-- Analytics Summary -->

    <div class="card">

        <div class="card-header bg-primary text-white">
            Analytics Summary
        </div>

        <div class="card-body">

            <ul class="list-group">

                <li class="list-group-item">
                    Most Congested Road:
                    <strong>@ViewBag.TopRoad</strong>
                </li>

                <li class="list-group-item">
                    Fastest Road:
                    <strong>@ViewBag.FastestRoad</strong>
                </li>

                <li class="list-group-item">
                    Average Speed:
                    <strong>@ViewBag.AverageSpeed km/h</strong>
                </li>

                <li class="list-group-item">
                    Total Emergencies:
                    <strong>@ViewBag.TotalEmergencies</strong>
                </li>

                <li class="list-group-item">
                    Most Common Traffic Level:
                    <strong>@ViewBag.MostCommonTraffic</strong>
                </li>

            </ul>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    var roadNames = [
    @if (ViewBag.RoadNames != null)
    {
        foreach (var road in ViewBag.RoadNames)
        {
            <text>'@road', </text>
        }
    }
        ];

    var vehicleCounts = [
    @if (ViewBag.VehicleCounts != null)
    {
        foreach (var count in ViewBag.VehicleCounts)
        {
            <text>@count, </text>
        }
    }
        ];

    // Vehicle Chart

    new Chart(
        document.getElementById('vehicleChart'),
        {
            type: 'bar',

            data:
            {
                labels: roadNames,

                datasets:
                    [{
                        label: 'Vehicle Count',

                        data: vehicleCounts,

                        backgroundColor:
                            [
                                '#0d6efd',
                                '#198754',
                                '#ffc107',
                                '#dc3545',
                                '#6f42c1',
                                '#20c997',
                                '#fd7e14',
                                '#6610f2'
                            ]
                    }]
            },

            options:
            {
                responsive: true,
                plugins:
                {
                    legend:
                    {
                        display: false
                    }
                }
            }
        });

    // Traffic Distribution

    new Chart(
        document.getElementById('trafficPieChart'),
        {
            type: 'pie',

            data:
            {
                labels:
                    [
                        'Critical',
                        'Heavy',
                        'High',
                        'Medium',
                        'Low'
                    ],

                datasets:
                    [{
                        data:
                            [
    @ViewBag.CriticalCount,
    @ViewBag.HeavyCount,
    @ViewBag.HighCount,
    @ViewBag.MediumCount,
    @ViewBag.LowCount
                        ],

                        backgroundColor:
                            [
                                '#dc3545',
                                '#198754',
                                '#ffc107',
                                '#0dcaf0',
                                '#6c757d'
                            ]
                    }]
            }
        });

    // Emergency Chart

    new Chart(
        document.getElementById('emergencyChart'),
        {
            type: 'doughnut',

            data:
            {
                labels:
                    [
                        'Ambulance',
                        'Fire Brigade'
                    ],

                datasets:
                    [{
                        data:
                            [
    @ViewBag.AmbulanceCount,
    @ViewBag.FireBrigadeCount
                        ],

                        backgroundColor:
                            [
                                '#198754',
                                '#dc3545'
                            ]
                    }]
            },

            options:
            {
                responsive: true,

                plugins:
                {
                    legend:
                    {
                        position: 'bottom'
                    }
                }
            }
        });

</script>