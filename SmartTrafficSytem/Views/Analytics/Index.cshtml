@{
    ViewData["Title"] = "Traffic Analytics";
}

<div class="container-fluid">

    
    <h2 class="mb-4">
        📊 Traffic Analytics & Reporting Center
    </h2>

    <!-- KPI CARDS -->

    <div class="row">

        <div class="col-md-2">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h6>Total Vehicles</h6>
                    <h3>5,150</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h6>Peak Hour</h6>
                    <h3>08:00 AM</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h6>Emergencies</h6>
                    <h3>12</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h6>VIP Movements</h6>
                    <h3>4</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h6>Avg Delay</h6>
                    <h3>42 Sec</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card border-dark">
                <div class="card-body text-center">
                    <h6>Active Roads</h6>
                    <h3>15</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- CHARTS ROW 1 -->

    <div class="row">

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-primary text-white">

                    Traffic Trend Analysis

                </div>

                <div class="card-body">

                    <canvas id="trafficTrendChart"></canvas>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-success text-white">

                    Vehicle Distribution

                </div>

                <div class="card-body">

                    <canvas id="vehicleChart"></canvas>

                </div>

            </div>

        </div>

    </div>

    <br />

    <!-- CHARTS ROW 2 -->

    <div class="row">

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-danger text-white">

                    Top Congested Roads

                </div>

                <div class="card-body">

                    <canvas id="congestionChart"></canvas>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-warning text-dark">

                    Emergency Trends

                </div>

                <div class="card-body">

                    <canvas id="emergencyChart"></canvas>

                </div>

            </div>

        </div>

    </div>

    <br />

    <!-- REPORT TABLE -->

    <div class="card">

        <div class="card-header bg-dark text-white">

            Daily Traffic Report

        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>

                    <tr>

                        <th>Road Name</th>
                        <th>Vehicles</th>
                        <th>Traffic Level</th>
                        <th>Emergency Events</th>
                        <th>Avg Signal Delay</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>
                        <td>Murree Road</td>
                        <td>720</td>
                        <td>Critical</td>
                        <td>3</td>
                        <td>65 Sec</td>
                    </tr>

                    <tr>
                        <td>GT Road</td>
                        <td>650</td>
                        <td>Heavy</td>
                        <td>2</td>
                        <td>55 Sec</td>
                    </tr>

                    <tr>
                        <td>Islamabad Expressway</td>
                        <td>540</td>
                        <td>High</td>
                        <td>1</td>
                        <td>42 Sec</td>
                    </tr>

                    <tr>
                        <td>Srinagar Highway</td>
                        <td>420</td>
                        <td>Medium</td>
                        <td>0</td>
                        <td>25 Sec</td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>
    

</div>

@section Scripts{

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        // Traffic Trend Chart

        new Chart(
            document.getElementById('trafficTrendChart'),
            {
                type: 'line',

                data: {
                    labels: ['6 AM', '7 AM', '8 AM', '9 AM', '10 AM', '11 AM', '12 PM'],
                    datasets: [{
                        label: 'Vehicles',
                        data: [200, 450, 900, 1200, 950, 800, 700],
                        borderWidth: 3
                    }]
                }
            });

        // Vehicle Distribution

        new Chart(
            document.getElementById('vehicleChart'),
            {
                type: 'pie',

                data: {
                    labels: ['Cars', 'Bikes', 'Trucks', 'Buses', 'Wagons', 'Scooties'],
                    datasets: [{
                        data: [1250, 2100, 320, 180, 410, 890]
                    }]
                }
            });

        // Congested Roads

        new Chart(
            document.getElementById('congestionChart'),
            {
                type: 'bar',

                data: {
                    labels: [
                        'Murree',
                        'GT',
                        'IJP',
                        'Expressway',
                        'Srinagar'
                    ],
                    datasets: [{
                        label: 'Congestion %',
                        data: [95, 88, 82, 76, 68]
                    }]
                }
            });

        // Emergency Trends

        new Chart(
            document.getElementById('emergencyChart'),
            {
                type: 'line',

                data: {
                    labels: [
                        'Mon',
                        'Tue',
                        'Wed',
                        'Thu',
                        'Fri',
                        'Sat',
                        'Sun'
                    ],
                    datasets: [{
                        label: 'Emergency Events',
                        data: [2, 4, 3, 5, 2, 6, 4]
                    }]
                }
            });

    </script>

}
