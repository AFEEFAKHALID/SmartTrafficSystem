@{
    ViewData["Title"] = "Dashboard";
}

<div class="alert alert-success mb-3">
    🚦 Database Connected Successfully
</div>

<h1>Smart Traffic Control Center Dashboard</h1>

<div class="container-fluid">

   
    
    <div class="row">

        <div class="col-md-3">
            <div class="dashboard-card vehicle-card">
                <h5>Total Vehicles Today</h5>
                <hr />

                <p>🚗 Cars : @ViewBag.CarCount</p>
                <p>🏍 Bikes : @ViewBag.BikeCount</p>
                <p>🚚 Trucks : @ViewBag.TruckCount</p>
                <p>🚌 Buses : @ViewBag.BusCount</p>
                <p>🛵 Scooties : @ViewBag.ScootyCount</p>

                <h4>Total : @ViewBag.TotalVehicles</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card emergency-card">

                <h5>🚦 Emergency Route Status</h5>

                <hr />

                @if (ViewBag.EmergencyAlert == true)
                {
                    <p>
                        <strong>Priority Route:</strong><br />
                        @ViewBag.EmergencyRoad
                    </p>

                    <p>
                        <strong>Emergency Vehicle:</strong><br />
                        @ViewBag.EmergencyVehicle
                    </p>

                    <p>
                        <strong>Signal Status:</strong><br />
                        GREEN Corridor Active
                    </p>

                    <p>
                        <strong>Override Mode:</strong><br />
                        ENABLED
                    </p>

                    <span class="badge bg-success">
                        Emergency Corridor Open
                    </span>
                }
                else
                {
                    <p>
                        No Emergency Route Active
                    </p>

                    <span class="badge bg-secondary">
                        Normal Traffic Flow
                    </span>
                }

            </div>
        </div>
        <div class="col-md-3">
            <div class="dashboard-card vip-card">
                <h5>🚦 Traffic Signals</h5>
                <hr />

                @if (ViewBag.LatestSignal != null)
                {
                    <p><strong>Total Signals:</strong> @ViewBag.SignalCount</p>
                    <p><strong>Green:</strong> @ViewBag.LatestSignal.GreenDuration sec</p>
                    <p><strong>Yellow:</strong> @ViewBag.LatestSignal.YellowDuration sec</p>
                    <p><strong>Red:</strong> @ViewBag.LatestSignal.RedDuration sec</p>
                    <p><strong>Status:</strong> @ViewBag.LatestSignal.CurrentStatus</p>
                }
                else
                {
                    <p>No signal data found.</p>
                }
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card system-card">
                <h5>🖥 System Status</h5>
                <hr />

                <p><strong>Roads:</strong> @ViewBag.RoadCount</p>
                <p><strong>Traffic Records:</strong> @ViewBag.TrafficCount</p>
                <p><strong>Emergencies:</strong> @ViewBag.EmergencyCount</p>
                <p><strong>Database:</strong> CONNECTED</p>
            </div>
        </div>

    </div>
    @if (ViewBag.EmergencyAlert == true)
    {
        <br />

        <div class="card border-danger">

            <div class="card-header bg-danger text-white">

                🚑 Emergency Priority Route

            </div>

            <div class="card-body">

                <table class="table table-bordered">

                    <thead>

                        <tr>
                            <th>Road</th>
                            <th>Emergency Vehicle</th>
                            <th>Priority</th>
                            <th>Signal Status</th>
                            <th>Route Status</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>
                                @ViewBag.EmergencyRoad
                            </td>

                            <td>
                                @ViewBag.EmergencyVehicle
                            </td>

                            <td>
                                @ViewBag.EmergencyPriority
                            </td>

                            <td>
                                <span class="badge bg-success">
                                    GREEN
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-danger">
                                    Activated
                                </span>
                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>
    }
    <div class="row mt-4">

        <div class="col-md-3">
            <div class="card text-center p-3">
                <h3>🔔</h3>
                <h5>Notifications</h5>
                <p>15 Active Alerts</p>
                <a href="/Notification" class="btn btn-primary">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center p-3">
                <h3>⚠</h3>
                <h5>Incidents</h5>
                <p>3 Active Cases</p>
                <a href="/Incident" class="btn btn-warning">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center p-3">
                <h3>📈</h3>
                <h5>Predictions</h5>
                <p>Tomorrow Forecast</p>
                <a href="/Prediction" class="btn btn-success">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center p-3">
                <h3>📄</h3>
                <h5>Reports</h5>
                <p>Weekly Reports</p>
                <a href="/Report" class="btn btn-danger">
                    Open
                </a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">

                <h3>🚦</h3>

                <h5>Signal Logs</h5>

                <p>Signal History</p>

                <a href="/SignalLog"
                   class="btn btn-info">

                    Open

                </a>

            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">

                <h3>🚑</h3>

                <h5>Emergency History</h5>

                <p>Completed Routes</p>

                <a href="/EmergencyHistory"
                   class="btn btn-danger">

                    Open

                </a>

            </div>
        </div>

    </div>

    <br />

    <div class="card">
        <div class="card-header bg-dark text-white">
            Traffic Summary
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Metric</th>
                        <th>Count</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>Total Roads</td>
                        <td>@ViewBag.RoadCount</td>
                    </tr>

                    <tr>
                        <td>Total Vehicles</td>
                        <td>@ViewBag.TotalVehicles</td>
                    </tr>

                    <tr>
                        <td>Total Emergencies</td>
                        <td>@ViewBag.EmergencyCount</td>
                    </tr>

                    <tr>
                        <td>Total Signals</td>
                        <td>@ViewBag.SignalCount</td>
                    </tr>

                    <tr>
                        <td>Traffic Records</td>
                        <td>@ViewBag.TrafficCount</td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>
   

</div>
<script>

    setInterval(function () {

        location.reload();

    }, 10000);

</script>