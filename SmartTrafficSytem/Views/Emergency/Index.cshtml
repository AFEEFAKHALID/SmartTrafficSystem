@{
    ViewData["Title"] = "Emergency Management";
}

<div class="container-fluid">

    <h2 class="mb-4">
        🚑 Emergency Management Center
    </h2>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5>Total Emergencies</h5>
                    <h3>@ViewBag.TotalEmergencies</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h5>Active Emergencies</h5>
                    <h3>@ViewBag.ActiveEmergencies</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h5>High Priority</h5>
                    <h3>@ViewBag.HighPriority</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5>Ambulances</h5>
                    <h3>@ViewBag.AmbulanceCount</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Emergency Table -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Live Emergency Tracking
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>ID</th>
                        <th>Road Name</th>
                        <th>Emergency Vehicle</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Reported Time</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in ViewBag.EmergencyData)
                    {
                        <tr>

                            <td>@item.EmergencyId</td>

                            <td>@item.RoadName</td>

                            <td>@item.VehicleType</td>

                            <td>

                                @if (item.PriorityLevel == "High")
                                {
                                    <span class="badge bg-danger">
                                        High
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        @item.PriorityLevel
                                    </span>
                                }

                            </td>

                            <td>

                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        @item.Status
                                    </span>
                                }

                            </td>

                            <td>
                                @item.CreatedAt
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <!-- Emergency Vehicle Pie Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Emergency Vehicle Distribution
        </div>

        <div class="card-body">

            <canvas id="emergencyChart"></canvas>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    new Chart(
        document.getElementById('emergencyChart'),
        {
            type: 'pie',

            data:
            {
                labels:
                    [
                        'Ambulance',
                        'Fire Brigade'
                    ],

                datasets:
                    [{
                        data:
                            [
    @ViewBag.AmbulanceCount,
    @ViewBag.FireBrigadeCount
                    ],

                        backgroundColor:
                            [
                                '#198754',
                                '#dc3545'
                            ]
                    }]
            },

            options:
            {
                responsive: true,

                plugins:
                {
                    legend:
                    {
                        position: 'bottom'
                    }
                }
            }
        });

</script>
<script>

    setInterval(function () {

        location.reload();

    }, 5000);

</script>