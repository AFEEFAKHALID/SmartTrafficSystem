@{
    ViewData["Title"] = "Incident Management";
}

<div class="container-fluid">

    <h2 class="mb-4">
        ⚠ Incident Management Center
    </h2>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5>Total Incidents</h5>
                    <h3>@ViewBag.TotalIncidents</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h5>Open Incidents</h5>
                    <h3>@ViewBag.OpenIncidents</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h5>Resolved</h5>
                    <h3>@ViewBag.ResolvedIncidents</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5>Critical</h5>
                    <h3>@ViewBag.CriticalIncidents</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Incident Table -->

    <div class="card">

        <div class="card-header bg-warning">
            Active Incident Monitoring
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Incident Type</th>
                        <th>Road</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Date</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in ViewBag.Incidents)
                    {
                        <tr>

                            <td>@item.IncidentType</td>

                            <td>@item.RoadName</td>

                            <td>

                                @if (item.Severity == "Critical")
                                {
                                    <span class="badge bg-danger">
                                        Critical
                                    </span>
                                }
                                else if (item.Severity == "High")
                                {
                                    <span class="badge bg-warning text-dark">
                                        High
                                    </span>
                                }
                                else if (item.Severity == "Medium")
                                {
                                    <span class="badge bg-info text-dark">
                                        Medium
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Low
                                    </span>
                                }

                            </td>

                            <td>

                                @if (item.Status == "Open")
                                {
                                    <span class="badge bg-danger">
                                        Open
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Resolved
                                    </span>
                                }

                            </td>

                            <td>@item.Description</td>

                            <td>
                                @item.CreatedAt.ToString("dd-MMM-yyyy")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>