@{
    ViewData["Title"] = "Traffic Monitoring";

    var trafficData = ViewBag.TrafficData;
}

<div class="container-fluid">

    <h2 class="mb-4">
        🚗 Live Traffic Monitoring Center
    </h2>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5>Total Active Roads</h5>
                    <h3>@ViewBag.TotalRoads</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h5>Low Traffic Roads</h5>
                    <h3>@ViewBag.LowTrafficRoads</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h5>High Traffic Roads</h5>
                    <h3>@ViewBag.HighTrafficRoads</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5>Emergency Routes</h5>
                    <h3>@ViewBag.EmergencyRoutes</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Traffic Table -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Real-Time Road Monitoring
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Road Name</th>
                        <th>Vehicles</th>
                        <th>Traffic Level</th>
                        <th>Average Speed</th>
                        <th>Signal Status</th>
                        <th>Emergency Vehicle</th>
                        <th>Priority</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in ViewBag.TrafficData)
                    {
                        <tr>

                            <td>@item.RoadName</td>

                            <td>@item.VehicleCount</td>

                            <td>

                                @if (item.TrafficLevel == "Critical")
                                {
                                    <span class="badge bg-danger">
                                        @item.TrafficLevel
                                    </span>
                                }
                                else if (item.TrafficLevel == "Heavy")
                                {
                                    <span class="badge bg-success">
                                        @item.TrafficLevel
                                    </span>
                                }
                                else if (item.TrafficLevel == "High")
                                {
                                    <span class="badge bg-warning text-dark">
                                        @item.TrafficLevel
                                    </span>
                                }
                                else if (item.TrafficLevel == "Medium")
                                {
                                    <span class="badge bg-info text-dark">
                                        @item.TrafficLevel
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        @item.TrafficLevel
                                    </span>
                                }

                            </td>

                            <td>@item.AverageSpeed km/h</td>

                            <td>@item.SignalStatus</td>

                            <td>@item.EmergencyVehicle</td>

                            <td>@item.PriorityLevel</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <!-- Vehicle Count Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Vehicle Count by Road
        </div>

        <div class="card-body">

            <canvas id="vehicleChart"></canvas>

        </div>

    </div>

    <br />

    <!-- Pie Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Traffic Level Distribution
        </div>

        <div class="card-body">

            <canvas id="trafficPieChart"></canvas>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    var roadNames = [
    @foreach (var item in ViewBag.TrafficData)
    {
        <text>'@item.RoadName', </text>
    }
    ];

    var vehicleCounts = [
    @foreach (var item in ViewBag.TrafficData)
    {
        <text>@item.VehicleCount, </text>
    }
    ];

    var ctx =
        document.getElementById('vehicleChart');

    new Chart(ctx,
        {
            type: 'bar',

            data:
            {
                labels: roadNames,

                datasets:
                    [{
                        label: 'Vehicle Count',

                        data: vehicleCounts,

                        backgroundColor:
                            'rgba(54,162,235,0.6)',

                        borderColor:
                            'rgba(54,162,235,1)',

                        borderWidth: 1
                    }]
            },

            options:
            {
                responsive: true,

                scales:
                {
                    y:
                    {
                        beginAtZero: true
                    }
                }
            }
        });

    var pieCtx =
        document.getElementById('trafficPieChart');

    new Chart(pieCtx,
        {
            type: 'pie',

            data:
            {
                labels:
                    [
                        'Critical',
                        'Heavy',
                        'High',
                        'Medium',
                        'Low'
                    ],

                datasets:
                    [{
                        data:
                            [
    @ViewBag.CriticalCount,
    @ViewBag.HeavyCount,
    @ViewBag.HighCount,
    @ViewBag.MediumCount,
    @ViewBag.LowCount
                ],

                        backgroundColor:
                            [
                                '#dc3545',
                                '#198754',
                                '#ffc107',
                                '#0dcaf0',
                                '#6c757d'
                            ]
                    }]
            },

            options:
            {
                responsive: true,

                plugins:
                {
                    legend:
                    {
                        position: 'bottom'
                    }
                }
            }
        });

</script>
<script>

    setInterval(function () {

        location.reload();

    }, 5000);

</script>