@{
    ViewData["Title"] = "Signal Control";
}

<div class="container-fluid">

    <h2 class="mb-4">
        🚦 Traffic Signal Control Center
    </h2>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h5>Total Signals</h5>
                    <h3>@ViewBag.TotalSignals</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h5>Green Signals</h5>
                    <h3>@ViewBag.GreenSignals</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h5>Yellow Signals</h5>
                    <h3>@ViewBag.YellowSignals</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5>Red Signals</h5>
                    <h3>@ViewBag.RedSignals</h3>
                </div>
            </div>
        </div>

    </div>

    <br />

    <!-- Signal Monitoring Table -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Live Signal Monitoring & Control
        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Signal ID</th>
                        <th>Road Name</th>
                        <th>Red Duration</th>
                        <th>Yellow Duration</th>
                        <th>Green Duration</th>
                        <th>Status</th>
                        <th>Control</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in ViewBag.SignalData)
                    {
                        <tr>

                            <td>@item.SignalId</td>

                            <td>@item.RoadName</td>

                            <td>@item.RedDuration sec</td>

                            <td>@item.YellowDuration sec</td>

                            <td>@item.GreenDuration sec</td>

                            <td>

                                @if (item.CurrentStatus == "Green")
                                {
                                    <span class="badge bg-success">
                                        Green
                                    </span>
                                }
                                else if (item.CurrentStatus == "Yellow")
                                {
                                    <span class="badge bg-warning text-dark">
                                        Yellow
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Red
                                    </span>
                                }

                            </td>

                            <td>

                                <form asp-action="UpdateSignal"
                                      method="post">

                                    <input type="hidden"
                                           name="signalId"
                                           value="@item.SignalId" />

                                    <button type="submit"
                                            name="status"
                                            value="Green"
                                            class="btn btn-success btn-sm">
                                        Green
                                    </button>

                                    <button type="submit"
                                            name="status"
                                            value="Yellow"
                                            class="btn btn-warning btn-sm">
                                        Yellow
                                    </button>

                                    <button type="submit"
                                            name="status"
                                            value="Red"
                                            class="btn btn-danger btn-sm">
                                        Red
                                    </button>

                                </form>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <!-- Signal Status Pie Chart -->

    <div class="card">

        <div class="card-header bg-dark text-white">
            Signal Status Distribution
        </div>

        <div class="card-body">

            <canvas id="signalPieChart"></canvas>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    new Chart(
        document.getElementById('signalPieChart'),
        {
            type: 'pie',

            data:
            {
                labels:
                    [
                        'Green',
                        'Yellow',
                        'Red'
                    ],

                datasets:
                    [{
                        data:
                            [
    @ViewBag.GreenSignals,
    @ViewBag.YellowSignals,
    @ViewBag.RedSignals
                    ],

                        backgroundColor:
                            [
                                '#198754',
                                '#ffc107',
                                '#dc3545'
                            ]
                    }]
            },

            options:
            {
                responsive: true,

                plugins:
                {
                    legend:
                    {
                        position: 'bottom'
                    }
                }
            }
        });

</script>
<script>

    setInterval(function () {

        location.reload();

    }, 5000);

</script>